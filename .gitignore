# =============================================================================
# Bootcamp Redis — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Carpetas de soluciones (solo para instructores, nunca al repo público)
# ---------------------------------------------------------------------------
**/3-proyecto/solution/
**/solution/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# Entornos virtuales
.venv/
venv/
env/
ENV/

# pytest
.pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml
*.cover

# mypy / pyright
.mypy_cache/
.dmypy.json
.pyright/

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Archivos de entorno (contienen contraseñas)
.env
!.env.example

# Datos persistentes de Redis (volúmenes montados localmente)
**/redis-data/
**/data/*.rdb
**/data/*.aof

# ---------------------------------------------------------------------------
# Editores y sistema operativo
# ---------------------------------------------------------------------------
# VS Code
.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# JetBrains
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
redis-server.log

# ---------------------------------------------------------------------------
# Temporales y backups
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
*.orig
